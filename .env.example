# FoveaMIL 環境変数の雛形
#   このファイルを `.env` にコピーし，自分の環境の値を入れる（`.env` は git 管理外）
#       cp .env.example .env
#   読み込みは direnv（.envrc）か `set -a; source .env; set +a`

# --- 実験完了メール通知（任意，未設定なら通知をスキップ）---
# Gmail の「アプリパスワード」を使う（2 段階認証 → アプリパスワードを生成）
GMAIL_USER=your_account@gmail.com
GMAIL_APP_PASSWORD=your_16char_app_password
RECEIVE_USER=recipient@example.com

# --- WSI 置き場（座標抽出の入力ルート）---
# slide_id から WSI ファイルを解決するためのベースディレクトリ
WSI_BASE_PATH=/path/to/your/wsi/directory

# --- 特徴抽出エンコーダ ---
# Virchow2-mini の蒸留チェックポイント（.pt）の絶対パス
VIRCHOW_MINI_CHECKPOINT=/path/to/pretrained/virchow_mini_dinov2_1.25-40x.pt
# HuggingFace gated モデル（UNI2-h / Virchow2）の初回ロード用トークン（任意）
# HF_TOKEN=
# HuggingFace キャッシュ先（任意，既定は ~/.cache/huggingface）
# HF_HOME=

# --- 特徴抽出のバッチ設定（GPU に応じて調整）---
PREPROCESS_BATCH_SIZE=256
PREPROCESS_NUM_WORKERS=4

# --- 学習・sweep の特徴ルート（base）---
# {encoder}/{mag}x/{slide_id}.h5 の親ディレクトリ，encoder と倍率は自動付与される
# sweep 設定の resolve.feature_root に ${FEATURE_ROOT} で渡す
FEATURE_ROOT=/path/to/your/features

# --- WSI ステージング先（任意，ローカル SSD のディレクトリ）---
FOVEAMIL_STAGE_DIR=
